# ============================================================
# Problema da Feira — .gitignore
# ============================================================

# ------------------------------------------------------------
# Logs gerados pelo agente
# ------------------------------------------------------------
src/logs/*
!src/logs/.gitkeep


# ------------------------------------------------------------
# Python
# ------------------------------------------------------------

# Bytecode e cache
__pycache__/
*.py[cod]
*$py.class

# Distribuição e empacotamento
dist/
build/
*.egg-info/
*.egg

# Ambientes virtuais
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# Jupyter Notebooks
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Editores e IDEs
# ------------------------------------------------------------

# VS Code
.vscode/

# JetBrains (PyCharm, IntelliJ etc.)
.idea/

# Emacs
*~
\#*\#
.\#*

# Vim
*.swp
*.swo

# ------------------------------------------------------------
# Sistema operacional
# ------------------------------------------------------------

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Linux
.directory


